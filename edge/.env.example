# Edge Node Configuration
NODE_ID=GTN-BORDER-01
IMS_API_URL=https://ims.internal.gov.rw/api/v1
NODE_API_KEY=CHANGE_ME_NODE_API_KEY
NODE_TLS_CERT_PATH=/certs/node.crt
NODE_TLS_KEY_PATH=/certs/node.key
IMS_CA_CERT_PATH=/certs/ims_ca.crt

# Face Recognition
FACE_MODEL=buffalo_l
SUSPECT_CACHE_PATH=/data/embeddings/suspects.npy
INTERPOL_CACHE_PATH=/data/embeddings/interpol.npy
EMBEDDING_REFRESH_INTERVAL_SECONDS=3600

# ANPR
ANPR_ENABLED=true
ANPR_REGION=RW

# Camera
CAMERA_FPS=15
CAMERA_RESOLUTION_W=1920
CAMERA_RESOLUTION_H=1080
DETECTION_CONFIDENCE_THRESHOLD=0.85

# Offline
OFFLINE_EVENT_QUEUE_PATH=/data/offline_queue.jsonl
HEARTBEAT_INTERVAL_SECONDS=60
