# ============================================================
# IMS v3.0 — Environment Variables (copy to .env and fill in)
# ============================================================

# --- Database ---
POSTGRES_DB=ims_db
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_256BIT_SECRET
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- NIDA Integration ---
NIDA_API_BASE_URL=https://nida.gov.rw/api/v1
NIDA_API_CERT_PATH=/certs/nida_client.crt
NIDA_API_KEY_PATH=/certs/nida_client.key
NIDA_CA_CERT_PATH=/certs/nida_ca.crt

# --- Interpol I-24/7 ---
INTERPOL_GATEWAY_URL=https://interpol-gateway.niss.gov.rw
INTERPOL_API_KEY=CHANGE_ME_INTERPOL_KEY
INTERPOL_CERT_PATH=/certs/interpol_client.crt

# --- Face Recognition ---
FACE_MATCH_THRESHOLD_HIGH=0.95
FACE_MATCH_THRESHOLD_PROBABLE=0.85
FACE_MATCH_THRESHOLD_POSSIBLE=0.70
FACE_EMBEDDING_DIM=512

# --- Storage ---
EVIDENCE_STORAGE_PATH=/app/storage/evidence
MAX_UPLOAD_SIZE_MB=50

# --- SIEM ---
SIEM_BULK_QUERY_LIMIT=50
SIEM_BULK_QUERY_WINDOW_SECONDS=600
SIEM_LOCATION_OVERACCESS_LIMIT=20
SIEM_LOCATION_OVERACCESS_WINDOW_SECONDS=3600
SIEM_NID_DAILY_SCAN_LIMIT=100
SIEM_OFF_HOURS_START=22
SIEM_OFF_HOURS_END=5
SIEM_INTERPOL_REVIEW_WINDOW_SECONDS=7200
SIEM_CAMERA_OFFLINE_THRESHOLD_MINUTES=15

# --- Notifications ---
NOTIFICATION_WEBHOOK_URL=
SMS_GATEWAY_URL=
SMS_API_KEY=

# --- Environment ---
ENVIRONMENT=development
LOG_LEVEL=INFO
DATA_RESIDENCY_COUNTRY=RW
